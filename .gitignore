# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example

# vercel
.vercel

# Claude Code internal files (but track shared project skills)
.claude/*
!.claude/skills/

# Opportunity scanner runtime state
opportunity-scans/.seen.json

# Proposal-writer: raw proprietary proposals kept local, not committed
.claude/skills/proposal-writer/references/winning-proposals/

# typescript
*.tsbuildinfo
next-env.d.ts

# Supabase CLI cache
/supabase/.temp/

# PWA generated files
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map

# Local development worktrees
/.worktrees/

# Proposal-writer: per-run docx build scratch
proposals/**/build-docx.js

# Evaluation-designer: per-run docx build scratch
evaluations/**/build-docx.js
